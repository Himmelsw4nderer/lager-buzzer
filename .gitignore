# PlatformIO build artifacts (each project also has its own .gitignore)
firmware/**/.pio/

# Local device config - contains machine-specific ports and MACs, do not commit
device_macs.mk
device_ports.mk

# Soundboard: event-specific config and audio files, not repo content
server/soundboard/modes.json
server/soundboard/sounds/*
!server/soundboard/sounds/.gitkeep

# Editor
.vscode/
.idea/
*.swp
*.swo
.zed/

# OS
.DS_Store
Thumbs.db

__pycache__/
